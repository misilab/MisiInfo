    "tooltip.Bits / (Pixel × Image)" : {
      "comment" : "Tooltip explaining the meaning of the \"Bits / (Pixel × Image)\" field.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitrate divided by (width × height × fps). Quality indicator: web H.264 ~0.1, broadcast ~0.4, ProRes 422 HQ ~5+."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tasa dividida por (ancho × alto × fps). Indicador de calidad: H.264 web ~0.1, broadcast ~0.4, ProRes 422 HQ ~5+."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitrate divisé par (largeur × hauteur × fps). Indicateur de qualité : H.264 web ~0.1, broadcast ~0.4, ProRes 422 HQ ~5+."
          }
        }
      }
    },
    "tooltip.Codec" : {
      "comment" : "Explanation of the codec used in a video.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Video compression algorithm. H.264 is universal, H.265/HEVC is more efficient, ProRes for pro editing, AV1 for web."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algoritmo de compresión de vídeo. H.264 universal, H.265/HEVC más eficiente, ProRes para edición profesional, AV1 para la web."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algorithme de compression vidéo. H.264 universel, H.265/HEVC plus efficace, ProRes pour montage pro, AV1 pour le web."
          }
        }
      }
    },
    "tooltip.Conteneur" : {
      "comment" : "Explanation of the term \"Conteneur\" used in the context of a media file.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "File format (container) that wraps video, audio, subtitle and metadata streams. MP4, MOV, MKV…"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Formato de archivo (contenedor) que encapsula los flujos de vídeo, audio, subtítulos y metadatos. MP4, MOV, MKV…"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Format de fichier (boîte) qui encapsule les flux vidéo, audio, sous-titres et métadonnées. MP4, MOV, MKV…"
          }
        }
      }
    },
    "tooltip.Débit global" : {
      "comment" : "Explanation of the \"Débit global\" tooltip.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Total data per second for video + audio + all streams. Higher means more quality but bigger file."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cantidad total de datos por segundo, vídeo + audio + todos los flujos. Más alto significa más calidad y mayor tamaño."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quantité totale de données par seconde, vidéo + audio + tous flux. Plus c'est élevé, plus la qualité (et la taille) est grande."
          }
        }
      }
    },
    "tooltip.Disposition des canaux" : {
      "comment" : "Tooltip explaining the audio channel layout.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Physical speaker positions. L=left, R=right, C=center, LFE=bass (subwoofer), Ls/Rs=rear surround."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Posición física de altavoces. L=izquierda, R=derecha, C=centro, LFE=graves (subwoofer), Ls/Rs=surround trasero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Position physique des haut-parleurs. L=gauche, R=droit, C=centre, LFE=basses (subwoofer), Ls/Rs=arrière surround."
          }
        }
      }
    },
    "tooltip.Drop frame" : {
      "comment" : "Tooltip for the \"Drop frame\" label.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compensation for 29.97/59.94 fps: skips 2 frames/min (except round minutes) to resync with wall clock (NTSC)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compensación para 29.97/59.94 fps: salta 2 frames/min (excepto minutos redondos) para resincronizar con el reloj real (NTSC)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compensation pour 29.97/59.94 fps : on saute 2 frames/min (sauf les minutes rondes) pour resynchroniser avec l'horloge murale (NTSC)."
          }
        }
      }
    },
    "tooltip.Échantillons par frame" : {
      "comment" : "Tooltip explaining the number of audio samples per frame.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Audio samples per codec frame. 1024 for AAC LC, 2048 HE-AAC, 1152 MP3, 1536 AC-3, 1 for raw PCM."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestras de audio por frame de códec. 1024 AAC LC, 2048 HE-AAC, 1152 MP3, 1536 AC-3, 1 para PCM crudo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nombre d'échantillons audio dans une frame de codec. 1024 pour AAC LC, 2048 HE-AAC, 1152 MP3, 1536 AC-3, 1 pour PCM brut."
          }
        }
      }
    },
    "tooltip.Endianness" : {
      "comment" : "Tooltip explanation for the \"Endianness\" term.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PCM byte order. Big Endian = most significant byte first (AIFF). Little Endian = least significant first (WAV, CAF)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Orden de bytes PCM. Big Endian = byte alto primero (AIFF). Little Endian = byte bajo primero (WAV, CAF)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ordre des octets PCM. Big Endian = octet fort en premier (AIFF). Little Endian = octet faible en premier (WAV, CAF)."
          }
        }
      }
    },
    "tooltip.Espace de couleurs" : {
      "comment" : "Tooltip explaining the meaning of the \"Espace de couleurs\" field.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "YUV: luminance separated from color (video standard). RGB: 3 independent color channels. RGBA includes an alpha (transparency) channel."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "YUV: luminancia separada del color (estándar de vídeo). RGB: 3 canales de color. RGBA incluye canal alfa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "YUV : luminance séparée des couleurs (standard vidéo). RGB : 3 canaux couleur indépendants. RGBA inclut un canal alpha (transparence)."
          }
        }
      }
    },
    "tooltip.Fonction de transfert" : {
      "comment" : "Tooltip explaining the function of the color transfer function.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gamma curve. BT.709 = SDR. PQ (SMPTE 2084) = absolute HDR10. HLG = broadcast HDR. sRGB = computer screens. Linear = pre-render."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Curva gamma. BT.709 = SDR. PQ (SMPTE 2084) = HDR10 absoluto. HLG = HDR de difusión. sRGB = pantallas informáticas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Courbe gamma. BT.709 = SDR. PQ (SMPTE 2084) = HDR10 absolu. HLG = HDR diffusion. sRGB = écrans informatiques. Linear = pré-render."
          }
        }
      }
    },
    "tooltip.Fréquence d'échantillonnage" : {
      "comment" : "Explication détaillée du format de fréquence d'échantillonnage.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Audio samples per second. 44.1 kHz CD, 48 kHz broadcast/cinema, 96/192 kHz audiophile/master."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestras de audio por segundo. 44.1 kHz CD, 48 kHz broadcast/cine, 96/192 kHz audiófilo/master."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nombre de mesures audio par seconde. 44.1 kHz CD, 48 kHz broadcast/cinéma, 96/192 kHz audiophile/master."
          }
        }
      }
    },
    "tooltip.Fréquence d'images" : {
      "comment" : "Explication détaillée sur le format de la fréquence d'images.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frames per second. 23.976 cinema, 24 true cinema, 25 PAL, 29.97 NTSC, 50/60 HD broadcast, 120 slow motion."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imágenes por segundo. 23.976 cine, 24 cine real, 25 PAL, 29.97 NTSC, 50/60 broadcast HD, 120 cámara lenta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nombre d'images par seconde. 23.976 cinéma, 24 cinéma true, 25 PAL, 29.97 NTSC, 50/60 broadcast HD, 120 slow motion."
          }
        }
      }
    },
    "tooltip.ftyp" : {
      "comment" : "Explanation of the `ftyp` box in a video file.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MP4/MOV ftyp atom: major brand + compatible brands, indicates which standards the file complies with."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Átomo ftyp del archivo MP4/MOV: marca principal + marcas compatibles, indica los estándares cumplidos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atom ftyp du fichier MP4/MOV : marque majeure (mp42, qt) + marques compatibles, indique les standards respectés."
          }
        }
      }
    },
    "tooltip.HDR" : {
      "comment" : "Tooltip for the HDR field.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "High Dynamic Range: peak luminance >1000 nits, wide BT.2020 gamut. HDR10 static, HDR10+ dynamic, HLG broadcast, Dolby Vision premium."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alto rango dinámico: pico de luminancia >1000 nits, gama amplia BT.2020. HDR10 estático, HDR10+ dinámico, HLG broadcast, Dolby Vision premium."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "High Dynamic Range : luminance pic >1000 nits, gamut élargi BT.2020. HDR10 statique, HDR10+ dynamique, HLG broadcast, Dolby Vision premium."
          }
        }
      }
    },
    "tooltip.Matrice YCbCr" : {
      "comment" : "Tooltip explaining the meaning of the matrix YCbCr.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coefficients for RGB ↔ YCbCr conversion. BT.709 for HD, BT.2020 for UHD/HDR, BT.601 for SD. Should match Primaries."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coeficientes de conversión RGB ↔ YCbCr. BT.709 HD, BT.2020 UHD/HDR, BT.601 SD. Debe coincidir con los Primarios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coefficients de conversion RGB ↔ YCbCr. BT.709 pour HD, BT.2020 pour UHD/HDR, BT.601 pour SD. Doit matcher les Primaries."
          }
        }
      }
    },
    "tooltip.MaxCLL" : {
      "comment" : "Tooltip explanation for the MaxCLL field.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maximum Content Light Level: peak luminance of brightest pixel in content (nits). Static HDR10 metadata."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maximum Content Light Level: luminancia pico del píxel más brillante (nits). Metadato HDR10 estático."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maximum Content Light Level : luminance pic du pixel le plus brillant du contenu (en nits). Métadonnée HDR10 statique."
          }
        }
      }
    },
    "tooltip.MaxFALL" : {
      "comment" : "Tooltip explanation for the MaxFALL field.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maximum Frame Average Light Level: max average luminance per frame across the program. Static HDR10 metadata."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maximum Frame Average Light Level: luminancia media máxima por frame en todo el programa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maximum Frame Average Light Level : luminance moyenne par frame, maximum sur le programme. Métadonnée HDR10 statique."
          }
        }
      }
    },
    "tooltip.MDCV" : {
      "comment" : "Tooltip explanation for the Mastering Display Color Volume.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mastering Display Color Volume: info about the display used to grade the program (typical P3 D65 1000 nits). Static HDR10."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Volumen de color del display de masterización: info del monitor usado para etalonar (típico P3 D65 1000 nits). HDR10 estático."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mastering Display Color Volume : info sur l'écran sur lequel le programme a été étalonné (P3 D65 1000 nits typique). HDR10 statique."
          }
        }
      }
    },
    "tooltip.Mode de compression" : {
      "comment" : "Explication détaillée d'un terme technique.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lossy: most codecs (H.264, AAC). Lossless: ProRes, ALAC, FLAC (preserves original). Uncompressed: raw pixels/PCM."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con pérdida: la mayoría (H.264, AAC). Sin pérdida: ProRes, ALAC, FLAC (preserva el original). Sin comprimir: píxeles/PCM crudos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avec perte : la majorité (H.264, AAC). Sans perte : ProRes, ALAC, FLAC (préserve l'original). Non compressé : raw pixels/PCM."
          }
        }
      }
    },
    "tooltip.Mode du débit images" : {
      "comment" : "Explication détaillée sur le mode du débit des images.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CFR (Constant Frame Rate): fixed intervals — preferred for editing. VFR: variable intervals, common in screen captures."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CFR (tasa constante): intervalos fijos — preferible para edición. VFR: variable, común en capturas de pantalla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CFR (Constant Frame Rate) : intervalles fixes — préférable au montage. VFR : intervalles variables, courant sur captures écran."
          }
        }
      }
    },
    "tooltip.Ordre des trames" : {
      "comment" : "Explication détaillée sur le format d'un ordre de trames.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive: 1 full image per frame. Interlaced: 2 half-images (fields) alternated, inherited from analog broadcast."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progresivo: 1 imagen completa por frame. Entrelazado: 2 medias imágenes alternadas, heredado del broadcast analógico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressif : 1 image complète par frame. Entrelacé : 2 demi-images (champs) alternés, hérité du broadcast analogique."
          }
        }
      }
    },
    "tooltip.Pixel aspect ratio" : {
      "comment" : "Tooltip explaining the pixel aspect ratio.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Width/height ratio of individual pixels. 1.000 = square. Higher = anamorphic (e.g. HDV 1080i = 1.333)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relación ancho/alto de los píxeles individuales. 1.000 = cuadrados. Mayor = anamórfico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rapport largeur/hauteur des pixels individuels. 1.000 = carrés. Plus élevé = anamorphique (ex: HDV 1080i = 1.333)."
          }
        }
      }
    },
    "tooltip.Plage de couleurs" : {
      "comment" : "Explication de la plage de couleurs.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Full (PC): 0–255 in 8-bit, max contrast for computer. Limited (TV): 16–235, SMPTE broadcast standard."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completo (PC): 0–255 en 8 bits, máximo contraste. Limitado (TV): 16–235, estándar broadcast SMPTE."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Full (PC) : 0–255 en 8 bits, max contraste pour ordinateur. Limited (TV) : 16–235, standard broadcast SMPTE."
          }
        }
      }
    },
    "tooltip.Primaries" : {
      "comment" : "Tooltip explaining the primaries (gamut) of a color.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Color gamut. BT.709 = standard SDR HD. BT.2020 = UHD/HDR (wide gamut). DCI-P3 = digital cinema. EBU/SMPTE-C = legacy SD."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gama de color. BT.709 = SDR HD estándar. BT.2020 = UHD/HDR. DCI-P3 = cine digital."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gamut couleur. BT.709 = SDR HD standard. BT.2020 = UHD/HDR (large gamut). DCI-P3 = cinéma numérique. EBU/SMPTE-C = SD historique."
          }
        }
      }
    },
    "tooltip.Profil / Level" : {
      "comment" : "Explanation of the \"Profil / Level\" field.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profile: codec subset (Baseline, Main, High, Main 10). Level: bitrate and resolution cap. e.g. High@L4.2 = 1080p60."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perfil: subconjunto del códec. Nivel: límite de tasa y resolución. Ej.: High@L4.2 = 1080p60."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profil : sous-ensemble du codec (Baseline, Main, High, Main 10). Level : limite de bitrate et résolution. Ex: High@L4.2 = 1080p60."
          }
        }
      }
    },
    "tooltip.Profil audio" : {
      "comment" : "Explanation of the audio profile.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AAC codec variant. LC (Low Complexity) standard. HE-AAC (SBR) for low bitrates. HE-AAC v2 (PS) for low-bandwidth stereo."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Variante del códec AAC. LC (Low Complexity) estándar. HE-AAC (SBR) tasas bajas. HE-AAC v2 (PS) estéreo de baja banda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Variante du codec AAC. LC (Low Complexity) standard. HE-AAC (SBR) pour bitrates faibles. HE-AAC v2 (PS) pour stéréo basse bande."
          }
        }
      }
    },
    "tooltip.Profondeur par composante" : {
      "comment" : "Tooltip explaining the depth per channel of a sample format.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bits per color channel. 8-bit = 256 levels (SDR). 10-bit = 1024 levels (HDR / pro). 12-bit ProRes 4444 for grading."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bits por canal de color. 8 bits = 256 niveles (SDR). 10 bits = 1024 niveles (HDR / pro). 12 bits ProRes 4444 para etalonaje."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nombre de bits par couleur. 8 bits = 256 niveaux (SDR). 10 bits = 1024 niveaux (HDR / pro). 12 bits ProRes 4444 pour étalonnage."
          }
        }
      }
    },
    "tooltip.Quantification" : {
      "comment" : "Explanation of the audio quantification mode.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bits per audio sample. 16-bit CD/streaming (96 dB dynamic). 24-bit broadcast/master (144 dB). 32-bit float production."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bits por muestra de audio. 16 bits CD/streaming. 24 bits broadcast/master. 32 bits float producción."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bits par échantillon audio. 16 bits CD/streaming (96 dB dynamique). 24 bits broadcast/master (144 dB). 32 bits float production."
          }
        }
      }
    },
    "tooltip.Résolution d'affichage" : {
      "comment" : "Explication détaillée de la résolution d'affichage.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Size at which the video should be displayed after applying pixel aspect ratio (key for anamorphic)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tamaño al que debe mostrarse el vídeo después de aplicar el pixel aspect ratio (clave para anamórfico)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Taille à laquelle la vidéo doit s'afficher après application du pixel aspect ratio (essentiel pour anamorphique)."
          }
        }
      }
    },
    "tooltip.Résolution encodée" : {
      "comment" : "Tooltip explaining the resolution of the encoded video.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pixel size of the video stream as stored in the file (may differ from display if pixels are non-square)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tamaño en píxeles del flujo de vídeo tal como se almacena (puede diferir de la visualización si los píxeles no son cuadrados)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Taille en pixels du flux vidéo tel qu'il est stocké dans le fichier (peut différer de l'affichage si pixels non carrés)."
          }
        }
      }
    },
    "tooltip.Sous-échantillonnage" : {
      "comment" : "Tooltip explaining the concept of sub-sampling.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4:4:4 = no reduction (ideal for grading). 4:2:2 = horizontally reduced chroma (broadcast). 4:2:0 = even more compressed (web/streaming)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4:4:4 = sin reducción (ideal etalonaje). 4:2:2 = croma reducida horizontalmente (broadcast). 4:2:0 = más comprimido (web/streaming)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4:4:4 = pas de réduction (idéal grading). 4:2:2 = chrominance réduite horizontalement (broadcast). 4:2:0 = encore plus comprimé (web/streaming)."
          }
        }
      }
    },
    "tooltip.Timecode" : {
      "comment" : "Tooltip explaining the meaning of a timecode.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
