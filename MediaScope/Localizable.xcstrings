          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repère temporel SMPTE HH:MM:SS:FF pour chaque image. Identifie chaque frame de manière unique pour le montage et le conformer."
          }
        }
      }
    },
